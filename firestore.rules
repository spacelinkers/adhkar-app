rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function userEmail() {
      return request.auth.token.email;
    }
    function isAllowed() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/allowlist/$(userEmail()));
    }
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(userEmail()));
    }

    // ── Allowlist: each user reads only their own entry ───────────────────────
    match /allowlist/{email} {
      allow read:  if isSignedIn() && userEmail() == email;
      allow write: if false;
    }

    // ── Admins: each user reads only their own entry ──────────────────────────
    match /admins/{email} {
      allow read:  if isSignedIn() && userEmail() == email;
      allow write: if false;
    }

    // ── Predefined Dua library ────────────────────────────────────────────────
    // All allowed users can read; only admins can create / update / delete.
    match /duas/{duaId} {
      allow read:   if isAllowed();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Per-user data ─────────────────────────────────────────────────────────
    // Owner access only, and email must still be on the allowlist.
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn()
        && request.auth.uid == userId
        && isAllowed();
    }
  }
}
